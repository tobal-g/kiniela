NODE_ENV=development
PORT=3001
HOST=0.0.0.0
DATABASE_URL=file:./data/kiniela.sqlite
API_FOOTBALL_KEY=replace-with-api-football-key
AUTH_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGIN=http://localhost:3000
SYNC_ENABLED=false

# Used only by pnpm --filter @kiniela/api admin:create
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=replace-with-at-least-12-characters
