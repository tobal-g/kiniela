{
  "name": "kiniela",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --recursive build",
    "typecheck": "pnpm --recursive typecheck",
    "test": "pnpm --recursive test",
    "db:migrate": "pnpm --filter @kiniela/api db:migrate",
    "dev:api": "pnpm --filter @kiniela/api dev",
    "start": "pnpm --filter @kiniela/api start"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
